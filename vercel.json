{
  "version": 2,
  "cleanUrls": true,
  "build": {
    "env": {
      "DIST_DIR": "dist" 
    }
  },
  "routes": [
    {
      "src": "/_assets/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}